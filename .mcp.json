{
  "mcpServers": {
    "e2b": {
      "command": "npx",
      "args": ["-y", "@e2b/mcp-server"],
      "env": {
        "E2B_API_KEY": "${E2B_API_KEY}"
      },
      "description": "Cloud sandboxed code execution for TypeScript and Python"
    },
    "daytona": {
      "command": "daytona",
      "args": ["mcp", "serve"],
      "description": "Container-based sandbox with full Rust/TypeScript support"
    },
    "omnisearch": {
      "command": "npx",
      "args": ["-y", "mcp-omnisearch"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}",
        "EXA_API_KEY": "${EXA_API_KEY}",
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      },
      "description": "Unified search across Tavily, Exa, and Perplexity"
    },
    "helius": {
      "command": "npx",
      "args": ["-y", "@dcspark/mcp-server-helius"],
      "env": {
        "HELIUS_API_KEY": "${HELIUS_API_KEY}"
      },
      "description": "Solana blockchain data: balances, transactions, assets, Jupiter swaps"
    },
    "memorygraph": {
      "command": "memorygraph",
      "description": "Knowledge graph with SQLite default, supports Neo4j backend"
    },
    "twitter": {
      "command": "npx",
      "args": ["-y", "@mbelinky/x-mcp-server"],
      "env": {
        "API_KEY": "${TWITTER_API_KEY}",
        "API_SECRET_KEY": "${TWITTER_API_SECRET}",
        "ACCESS_TOKEN": "${TWITTER_ACCESS_TOKEN}",
        "ACCESS_TOKEN_SECRET": "${TWITTER_ACCESS_TOKEN_SECRET}"
      },
      "description": "Twitter/X automation: post, search, engage"
    },
    "crawl4ai": {
      "command": "docker",
      "args": ["run", "--rm", "-i", "uysalsadi/crawl4ai-mcp-server:latest"],
      "description": "Free, self-hosted web scraping with anti-bot handling"
    },
    "mcpdoc": {
      "command": "uvx",
      "args": [
        "--from", "mcpdoc", "mcpdoc",
        "--urls", "Solana:https://solana.com/llms.txt",
        "--urls", "Helius:https://www.helius.dev/llms.txt",
        "--urls", "Jupiter:https://dev.jup.ag/llms.txt"
      ],
      "description": "Documentation via llms.txt: Solana, Helius, Jupiter"
    },
    "claude-context": {
      "command": "npx",
      "args": ["-y", "@zilliz/claude-context-mcp@latest"],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "MILVUS_TOKEN": "${ZILLIZ_API_KEY}"
      },
      "description": "Vector search + semantic codebase search with 40% token reduction"
    },
    "clickup": {
      "type": "http",
      "url": "https://mcp.clickup.com/mcp",
      "description": "ClickUp task management via official OAuth MCP"
    }
  }
}
